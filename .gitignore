# Game text is copyrighted — never commit the corpus. Ignore the *contents* of
# the root data/ dir (not the dir itself) so the negation below can re-include
# README, and so this never touches the src/discostyle/data/ package.
/data/*
!/data/README.md

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
build/
dist/

# Notebooks / tooling
.ipynb_checkpoints/
.ruff_cache/
.pytest_cache/

# Models & artifacts — the shipped demo models ARE committed (~4.9 MB + ~7.7 MB;
# TF-IDF vocabulary + LogReg coefficients, no full dialogue lines) so Streamlit
# Cloud can serve them without rebuilding from the (non-redistributable) corpus.
models/*.joblib
models/*.pkl
!models/tfidf_logreg.joblib
!models/tfidf_logreg_skills.joblib

# Reports: keep the .md/.csv summaries, ignore regenerable interactive HTML
reports/*.html

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
